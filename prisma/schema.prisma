generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  discordId     String    @unique
  username      String
  image         String?
  applications  Application[]
  createdAt     DateTime  @default(now())
}

model Application {
  id          String   @id @default(cuid())
  name        String
  age         String
  city        String?
  experience  String
  reason      String
  dailyHours  String?
  hasMic      Boolean  @default(false)
  acceptedRules Boolean @default(false)
  reviewFlag  String?
  status      String   @default("PENDING")
  decisionReason String?
  decidedBy   String?
  decidedAt   DateTime?
  internalNote String?
  interviewAt DateTime?
  interviewNote String?

  userId      String
  user        User     @relation(fields: [userId], references: [id])

  createdAt   DateTime @default(now())
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  message   String
  active    Boolean  @default(true)
  createdBy String?
  createdAt DateTime @default(now())
}
