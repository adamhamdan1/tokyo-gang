generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  discordId     String    @unique
  username      String
  image         String?
  applications  Application[]
  createdAt     DateTime  @default(now())
}

model Application {
  id          String   @id @default(cuid())
  name        String
  age         String
  city        String?
  experience  String
  reason      String
  dailyHours  String?
  hasMic      Boolean  @default(false)
  acceptedRules Boolean @default(false)
  reviewFlag  String?
  status      String   @default("PENDING")
  decisionReason String?
  decidedBy   String?
  decidedAt   DateTime?
  internalNote String?
  interviewAt DateTime?
  interviewNote String?

  userId      String
  user        User     @relation(fields: [userId], references: [id])

  createdAt   DateTime @default(now())
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  message   String
  active    Boolean  @default(true)
  createdBy String?
  createdAt DateTime @default(now())
}

model TokyoMember {
  id           String   @id @default(cuid())
  discordId    String   @unique
  username     String
  displayName  String
  image        String?
  inTokyoRole  Boolean  @default(true)
  status       String   @default("ACTIVE")
  internalRank String   @default("MEMBER")
  behaviorScore Int     @default(100)
  adminNote    String?
  lastSyncedAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  summons      Summon[]
  warnings     MemberWarning[]
  adminLogs    AdminLog[]
  rankChanges  RoleAudit[]
  leaveRequests LeaveRequest[]
  notes        MemberNote[]
  blacklistEntries BlacklistEntry[]
  complaintsFiled Complaint[] @relation("ComplaintReporter")
  complaintsAgainst Complaint[] @relation("ComplaintAccused")
}

model Summon {
  id          String      @id @default(cuid())
  memberId    String
  member      TokyoMember @relation(fields: [memberId], references: [id])
  reason      String
  details     String?
  summonedBy  String
  status      String      @default("ACTIVE")
  createdAt   DateTime    @default(now())
}

model Complaint {
  id          String      @id @default(cuid())
  reporterId  String
  reporter    TokyoMember @relation("ComplaintReporter", fields: [reporterId], references: [id])
  accusedId   String
  accused     TokyoMember @relation("ComplaintAccused", fields: [accusedId], references: [id])
  category    String
  reason      String
  evidenceUrl String?
  details     String?
  status      String      @default("OPEN")
  reviewedBy  String?
  adminNote   String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  votes        ComplaintVote[]
}

model MemberWarning {
  id          String      @id @default(cuid())
  memberId    String
  member      TokyoMember @relation(fields: [memberId], references: [id])
  reason      String
  severity    String      @default("NORMAL")
  details     String?
  issuedBy    String
  createdAt   DateTime    @default(now())
}

model AdminLog {
  id             String       @id @default(cuid())
  action         String
  title          String
  details        String?
  adminDiscordId String?
  targetType     String?
  targetId       String?
  targetMemberId String?
  targetMember   TokyoMember? @relation(fields: [targetMemberId], references: [id])
  createdAt      DateTime     @default(now())
}

model RoleAudit {
  id             String       @id @default(cuid())
  memberId       String
  member         TokyoMember  @relation(fields: [memberId], references: [id])
  action         String
  rank           String
  discordRoleId  String?
  reason         String?
  adminDiscordId String
  createdAt      DateTime     @default(now())
}

model LeaveRequest {
  id             String       @id @default(cuid())
  memberId       String
  member         TokyoMember  @relation(fields: [memberId], references: [id])
  reason         String
  startsAt       DateTime?
  endsAt         DateTime?
  status         String       @default("PENDING")
  reviewedBy     String?
  adminNote      String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model BlacklistEntry {
  id             String       @id @default(cuid())
  discordId      String
  username       String?
  reason         String
  active         Boolean      @default(true)
  adminDiscordId String
  memberId       String?
  member         TokyoMember? @relation(fields: [memberId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model MemberNote {
  id             String       @id @default(cuid())
  memberId       String
  member         TokyoMember  @relation(fields: [memberId], references: [id])
  note           String
  adminDiscordId String
  createdAt      DateTime     @default(now())
}

model ComplaintVote {
  id             String       @id @default(cuid())
  complaintId    String
  complaint      Complaint    @relation(fields: [complaintId], references: [id])
  adminDiscordId String
  vote           String
  note           String?
  createdAt      DateTime     @default(now())

  @@unique([complaintId, adminDiscordId])
}
