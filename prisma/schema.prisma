generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  discordId     String    @unique
  username      String
  image         String?
  applications  Application[]
  createdAt     DateTime  @default(now())
}

model Application {
  id          String   @id @default(cuid())
  name        String
  age         String
  city        String?
  experience  String
  reason      String
  dailyHours  String?
  hasMic      Boolean  @default(false)
  acceptedRules Boolean @default(false)
  reviewFlag  String?
  status      String   @default("PENDING")
  decisionReason String?
  decidedBy   String?
  decidedAt   DateTime?
  internalNote String?
  interviewAt DateTime?
  interviewNote String?

  userId      String
  user        User     @relation(fields: [userId], references: [id])

  createdAt   DateTime @default(now())
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  message   String
  active    Boolean  @default(true)
  createdBy String?
  createdAt DateTime @default(now())
}

model TokyoMember {
  id           String   @id @default(cuid())
  discordId    String   @unique
  username     String
  displayName  String
  image        String?
  inTokyoRole  Boolean  @default(true)
  lastSyncedAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  summons      Summon[]
  complaintsFiled Complaint[] @relation("ComplaintReporter")
  complaintsAgainst Complaint[] @relation("ComplaintAccused")
}

model Summon {
  id          String      @id @default(cuid())
  memberId    String
  member      TokyoMember @relation(fields: [memberId], references: [id])
  reason      String
  details     String?
  summonedBy  String
  status      String      @default("ACTIVE")
  createdAt   DateTime    @default(now())
}

model Complaint {
  id          String      @id @default(cuid())
  reporterId  String
  reporter    TokyoMember @relation("ComplaintReporter", fields: [reporterId], references: [id])
  accusedId   String
  accused     TokyoMember @relation("ComplaintAccused", fields: [accusedId], references: [id])
  category    String
  reason      String
  evidenceUrl String?
  details     String?
  status      String      @default("OPEN")
  reviewedBy  String?
  adminNote   String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}
